<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false">

  <targets>
    <target xsi:type="Console" name="console"
            layout="${longdate} ${uppercase:${level}} ${message}${onexception:${newline}${exception:format=tostring}}" />
    <target xsi:type="File" name="arquivo"
            fileName="${basedir}/logs/${shortdate}.log"
            layout="${longdate} ${uppercase:${level}} ${message} - ${exception:format=tostring}" />
  </targets>

  <rules>
    <logger name="Microsoft.*" maxlevel="Info" writeTo="" final="true" />
    <logger name="*" minlevel="Info" writeTo="console,arquivo" />
  </rules>
</nlog>
